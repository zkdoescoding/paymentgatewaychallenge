{
  "info": {
    "name": "Payment Gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8090"
    }
  ],
  "item": [
    {
      "name": "Payments",
      "item": [
        {
          "name": "Process Payment - Authorized",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('paymentId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_number\": \"2222405343248877\",\n  \"expiry_month\": 4,\n  \"expiry_year\": 2030,\n  \"currency\": \"GBP\",\n  \"amount\": 100,\n  \"cvv\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            }
          }
        },
        {
          "name": "Process Payment - Declined",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_number\": \"2222405343248158\",\n  \"expiry_month\": 4,\n  \"expiry_year\": 2030,\n  \"currency\": \"GBP\",\n  \"amount\": 100,\n  \"cvv\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            }
          }
        },
        {
          "name": "Process Payment - Rejected (expired card)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_number\": \"2222405343248877\",\n  \"expiry_month\": 1,\n  \"expiry_year\": 2020,\n  \"currency\": \"GBP\",\n  \"amount\": 100,\n  \"cvv\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            }
          }
        },
        {
          "name": "Process Payment - Rejected (multiple validation errors)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_number\": \"123\",\n  \"expiry_month\": 13,\n  \"expiry_year\": 2020,\n  \"currency\": \"XYZ\",\n  \"amount\": -1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            }
          }
        },
        {
          "name": "Get Payment by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/{{paymentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "{{paymentId}}"]
            }
          }
        },
        {
          "name": "Get Payment - Not Found (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "00000000-0000-0000-0000-000000000000"]
            }
          }
        },
        {
          "name": "Get Payment - Invalid UUID (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/not-a-valid-uuid",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "not-a-valid-uuid"]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            }
          }
        }
      ]
    }
  ]
}
